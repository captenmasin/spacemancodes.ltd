---
import Layout from "../layouts/Layout.astro";

import Particles from '../components/Particles/Particles.vue'

const products = [
    {name: "novogamer", domain: "novogamer.com", tagline: "Gaming writing platform", color: "#7c5cfc"},
    {name: "browser.is", domain: "browser.is", tagline: "Share your browser info", color: "#4a8ef5"},
    {name: "seotoolkit", domain: "seotoolkit.dev", tagline: "SEO & domain analysis", color: "#9b6bef"},
    {name: "bookbound", domain: "bookbound.app", tagline: "Personal book tracker", color: "#c97a52"},
    {name: "sitepulse", domain: "sitepulse.dev", tagline: "Monitor, fix, and optimise", color: "#e7e7e7", comingSoon: true},
];
---

<Layout>
    <Particles client:load class:list={'absolute z-0 inset-0'}
               particle-count={200}
               particle-spread={20}
               speed={0.1}
               particle-colors={['#ffffff']}
               move-particles-on-hover={true}
               particle-hover-factor={1}
               alpha-particles={true}
               particle-base-size={100}
               size-randomness={0}
               camera-distance={100}
               disable-rotation={true}
    />
    <div class="relative z-10 flex md:h-screen flex-col justify-between px-8 md:px-15 pt-13">
        <div class="font-mono text-[11px] tracking-[0.12em] text-[#2e3148]">
            SPACEMANCODES.LTD
        </div>
        <div class:list={'py-12 md:py-2 mt-4 '}>
            <svg class:list={'size-12 md:size-18 mb-4'} viewBox="0 0 326 326" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M148.037 0.636932C138.55 1.59201 125.688 4.39355 115.564 7.76816C76.9791 20.4389 44.5701 48.5818 26.6783 85.0021C19.4197 99.774 14.6443 114.992 12.3521 130.846C10.9514 140.206 10.7603 162.3 11.9701 171.277C15.7904 198.784 26.8057 225.016 43.806 246.729C45.7162 249.148 51.7014 255.515 57.0498 260.864C66.7916 270.478 66.8553 270.542 65.4545 271.497C62.2709 273.725 55.1396 281.366 52.4654 285.377C46.5439 294.291 43.9334 303.269 43.424 316.895L43.1057 326H163H282.894L282.576 316.959C282.385 311.801 281.748 305.816 281.111 303.142C278.31 291.108 272.197 281.366 262.01 272.707L258.89 270.032L262.01 267.358C271.942 258.954 282.83 246.41 291.681 233.23L296.074 226.672L286.396 221.833C281.047 219.159 276.59 216.93 276.527 216.866C276.463 216.803 277.928 213.619 279.838 209.799C294.928 179.3 297.475 143.771 286.778 111.553C282.321 98.0548 273.407 81.8185 264.429 70.6759C259.463 64.5634 247.301 52.7841 241.826 48.7092C239.406 46.9264 237.496 45.3346 237.496 45.0799C237.496 44.8252 239.597 40.1771 242.208 34.765L246.919 24.8959L240.17 21.0756C221.26 10.4424 204.195 4.45724 184.585 1.59201C176.562 0.382233 155.932 -0.127136 148.037 0.636932ZM174.779 22.2853C182.993 23.1131 192.353 24.8959 199.929 27.1244C206.933 29.2256 218.458 33.8099 218.267 34.383C218.14 34.6377 206.488 58.833 192.353 88.122L166.629 141.352H162.745C148.355 141.352 135.175 151.667 131.482 165.865C129.572 173.315 130.527 181.592 134.284 188.978C143.325 206.806 167.393 211.836 183.438 199.229C184.712 198.211 185.985 197.383 186.176 197.383C186.749 197.383 262.583 234.313 263.156 234.886C263.983 235.713 249.084 250.294 241.635 255.834L234.631 261.055H163H91.3689L85.3201 256.534C68.065 243.609 54.9486 227.818 45.8435 209.162C19.8017 155.805 33.3002 91.5603 78.6346 52.8478C105.058 30.3717 140.524 19.1017 174.779 22.2853ZM239.788 76.0244C249.212 85.4478 255.642 94.4892 260.991 105.695C275.381 135.94 275.126 170.45 260.227 200.375C258.444 204.005 256.788 206.934 256.534 206.934C255.706 206.934 248.511 203.495 225.08 191.971C212.473 185.795 200.694 180 198.911 179.173L195.663 177.708L195.345 172.105C194.899 165.356 193.244 160.708 189.296 154.914C186.749 151.157 186.495 150.52 187.195 149.056C187.577 148.165 196.81 128.872 207.761 106.205L227.563 65.0728L229.537 66.3463C230.556 67.1103 235.204 71.44 239.788 76.0244ZM168.094 164.465C171.341 166.184 173.824 170.195 173.824 173.697C173.824 179.491 168.73 184.649 163 184.649C155.487 184.649 150.202 176.69 153.067 169.749C155.55 163.764 162.299 161.408 168.094 164.465ZM236.541 283.658C241.762 285.059 246.028 287.479 250.612 291.745C254.051 294.992 258.508 301.677 258.508 303.651C258.508 304.161 232.529 304.352 163 304.352C93.4701 304.352 67.492 304.161 67.492 303.651C67.492 301.677 71.949 294.992 75.3873 291.745C79.908 287.606 84.2377 285.059 89.2041 283.722C94.4889 282.257 231.065 282.257 236.541 283.658Z" fill="white"/>
            </svg>
            <h1 class="mb-7 text-[clamp(46px,8vw,96px)] font-semibold md:font-bold leading-[0.95] tracking-[-0.04em] text-[#edf0fa]">
                We build<br/>things.
            </h1>
            <!--<p class="max-w-[360px] text-[15px] leading-[1.65] text-[#424666]">-->
            <!--  Out of this world-->
            <!--</p>-->
        </div>

        <div class="flex flex-col md:flex-row -mx-8 md:-mx-15 border-t border-[#12141f]">
            {products.map((p, i) => (
                    <a
                            href={`https://${p.domain}`}
                            target="_blank"
                            rel="noopener"
                            class:list={[
                                "group flex-1 no-underline transition-colors duration-150 hover:bg-[#0c0e1a]",
                                "pt-8 pb-8 md:pb-10",
                                i > 0 ? "pl-6" : "px-6",
                                i < products.length - 1 ? "pr-6 border-b md:border-b-0 md:border-r border-[#12141f]" : "",
                            ]}
                    >
                        <div
                                class="mb-3 h-2 w-2 rounded-full md:opacity-40 transition-opacity duration-150 group-hover:opacity-100"
                                style={`background:${p.color}`}
                        ></div>
                        <div class="mb-1 text-[13px] font-medium text-[#edf0fa] md:text-[#5a607e] transition-colors duration-150 group-hover:text-[#edf0fa]">
                            {p.domain} {p.comingSoon && <span class="text-[11px] font-normal text-[#edf0fa]/50 transition-colors duration-150 md:text-[#2e3148] group-hover:text-[#edf0fa]">coming soon</span> }
                        </div>
                        <div class="font-mono text-[11px] text-[#edf0fa]/50 md:text-[#2e3148] transition-colors duration-150 group-hover:text-[#edf0fa]">
                            {p.tagline}
                        </div>
                    </a>
            ))}
        </div>
    </div>
</Layout>
